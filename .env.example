# ============================================================
# PeraCut — Environment Variables
# Copy this file to .env and fill in the values you need.
# ============================================================

# ── Database (MySQL) ─────────────────────────────────────────
# Required for production; optional in dev (file-based fallback is used).
# Format: mysql://user:password@host:port/database
DATABASE_URL=

# ── Session / JWT ────────────────────────────────────────────
# Secret used to sign session cookies.  Use a long random string.
JWT_SECRET=

# ── Admin / Master Key ───────────────────────────────────────
# Protects the admin-only endpoints (e.g. /api/admin/leads.csv).
# Also allows the "master key" login on the Auth page.
PERACUT_MASTER_KEY=

# ── OAuth (optional) ─────────────────────────────────────────
# Leave empty to disable OAuth login; the app still works in guest mode.
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# These two are read by the Vite client build (prefix VITE_).
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ── Analytics — Umami (optional) ─────────────────────────────
# Only injected in PRODUCTION builds when both vars are present.
# Example: VITE_ANALYTICS_ENDPOINT=https://umami.example.com
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Storage — S3-compatible (optional) ───────────────────────
STORAGE_BASE_URL=
STORAGE_API_KEY=

# ── AI / Image generation (optional) ─────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
